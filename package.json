{
  "name": "furniture-app",
  "private": true,
  "version": "1.0.0",
  "description": "FurnishAR Premium - 3D Furniture Design App",
  "author": "FurnishAR Team",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev:frontend": "vite --port 5173 --strictPort",
    "dev:backend": "node server.js",
    "server": "node server.js",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "vite build",
    "start": "node server.js",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "FurnishAR Premium",
        "executableName": "FurnishAR",
        "extraResource": [
          "server.js",
          ".env"
        ],
        "ignore": [
          "/\\.git($|/)",
          "/node_modules/\\.bin($|/)",
          "/release($|/)",
          "/src($|/)"
        ]
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "FurnishAR"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "linux",
            "darwin"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@types/three": "^0.183.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "mysql2": "^3.18.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.0",
    "@electron-forge/maker-squirrel": "^7.8.0",
    "@electron-forge/maker-zip": "^7.8.0",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1",
    "wait-on": "^8.0.3"
  }
}